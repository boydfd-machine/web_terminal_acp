{
  "name": "web-terminal-acp-frontend",
  "private": true,
  "version": "2.5.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:docker": "playwright test --config=playwright.config.docker.ts",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:start": "npm run build && cross-env ELECTRON_DEV=1 electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder",
    "electron:dist:mac": "npm run build && electron-builder --mac",
    "electron:dist:mac:zip": "npm run build && electron-builder --mac zip",
    "electron:dist:win:portable": "npm run build && electron-builder --win portable -c.win.signAndEditExecutable=false",
    "electron:dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@xterm/xterm": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.2"
  }
}
